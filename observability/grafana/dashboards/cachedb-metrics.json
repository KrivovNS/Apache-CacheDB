      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (request_type, result) (increase(cachedb_requests_total[5m]))",
          "legendFormat": "{{request_type}} | {{result}}",
          "refId": "A"
        }
      ],
      "title": "Requests Success/Failure By Type (last 5m)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
